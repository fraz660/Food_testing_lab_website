# Environment Configuration
NODE_ENV=production
PORT=5000

# MongoDB Connection String
# For Local: mongodb://localhost:27017/ftl
# For Cloud: mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/ftl

# Authentication
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" to generate a strong secret
JWT_SECRET=your_super_secret_jwt_key_here

# Client URL (for CORS in production)
CLIENT_URL=https://ftl.org.in

# Mail Configuration (optional - for contact form notifications)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# CONTACT_RECEIVER_EMAIL=md@ftl.esse.co.in
